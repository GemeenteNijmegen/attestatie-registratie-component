# VerID OAuth server
VERID_ISSUER_URL=https://oauth.ssi.dev.ver.garden
VERID_CLIENT_SECRET=your-client-secret

# The URL VerID redirects back to after the wallet flow
# Must match the redirectUri registered with VerID
ARC_CALLBACK_ENDPOINT=http://localhost:3000/callback

# Where to redirect the user after the callback is processed
# status=true (issued) or status=false (aborted) is appended as a query parameter
ARC_REDIRECT_URL=http://localhost:3000/done

# Path to the VerID flows config JSON file (see flows.example.json)
FLOWS_CONFIG_PATH=./flows.json

# OpenProduct source mode: 'fake' (built-in mock) or 'real' (live API)
OPENPRODUCT_MODE=fake

# Required when OPENPRODUCT_MODE=real
# OPENPRODUCT_BASE_URL=https://your-openproduct-api.example.com
# OPENPRODUCT_API_TOKEN=your-api-token

# Port for the ARC HTTP server
PORT=3000

# PostgreSQL Configuration (Optional)
# If DATABASE_URL is set, PostgreSql store will be used instead of InMemory.
DATABASE_URL=postgresql://user:password@db:5432/arc_db

# These are used by the docker-compose db service
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=arc_db

# Internal port for the fake OpenProduct server (only used when OPENPRODUCT_MODE=fake)
# FAKE_OPENPRODUCT_PORT=9876
